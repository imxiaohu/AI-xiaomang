# ============================================
# AI小芒 后端环境变量配置示例
# 复制此文件为 .env 并填入真实凭证
# ！！！禁止将 .env 提交到代码仓库 ！！！
# ============================================

# ----- 阿里云通用凭证 -----
# 获取路径：阿里云控制台 → 访问控制 → 用户管理 → 创建 AccessKey
ALIYUN_ACCESS_KEY_ID=your_access_key_id_here
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret_here
ALIYUN_REGION=cn-shanghai

# ----- 通义千问 VL（视觉理解）-----
# 获取路径：阿里云百炼控制台 → 模型服务 → 通义千问VL → API-KEY
# 或通过 DashScope 控制台获取 API Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ----- 阿里云实时 ASR -----
# 获取路径：阿里云智能语音交互控制台 → 项目管理 → 创建实时语音识别项目
ALIYUN_ASR_APP_KEY=your_asr_app_key_here

# ----- 阿里云流式 TTS -----
# 获取路径：阿里云智能语音交互控制台 → 项目管理 → 创建语音合成项目
ALIYUN_TTS_APP_KEY=your_tts_app_key_here

# ----- 额度管控 -----
# 每日TTS额度上限（秒），超限自动切离线模式
DAILY_TTS_QUOTA=10.0

# ----- 会话配置 -----
# 会话过期时间（秒），默认600秒（10分钟）
SESSION_TIMEOUT=600
# SSE心跳间隔（秒），默认3秒
SSE_HEARTBEAT_INTERVAL=3
# 最大上下文轮次（每轮=user+assistant两条消息）
MAX_CONTEXT_ROUNDS=10

# ----- 开发模式 -----
# true=启用Mock响应（无需阿里云凭证），false=使用真实阿里云服务
DEBUG=true

# ----- Omni 模式 -----
# true=使用 Omni Realtime 端到端模型（覆盖 VL+TTS 分离模式），false=使用 VL+TTS 分离
OMNI_MODE=false
# Omni 模型：qwen3.5-omni-plus-realtime / qwen3.5-omni-flash-realtime
OMNI_MODEL=qwen3.5-omni-flash-realtime
# Omni 音色：3.5 系列默认 Tina；3-omni-flash-realtime 默认 Cherry
# 注意：voice 参数必须与模型系列匹配，否则 400 报错
OMNI_VOICE=Tina

# ----- 测试模式 -----
# true=跳过 token 认证校验（本地/测试环境联调），false=校验 token
TEST_MODE=true
