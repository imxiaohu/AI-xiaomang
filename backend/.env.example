# ============================================
# AI小芒 后端环境变量配置示例
# 复制此文件为 .env 并填入真实凭证
# ！！！禁止将 .env 提交到代码仓库 ！！！
# ============================================

# ----- 百炼平台 API Key（VL / TTS / ASR / Omni 共用）-----
# 获取路径：阿里云百炼控制台 → API-KEY 管理
# 网址：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ----- 阿里云区域（默认 cn-shanghai）-----
ALIYUN_REGION=cn-shanghai

# ----- TTS 模型与音色 -----
TTS_MODEL=qwen3-tts-flash-realtime
TTS_VOICE=Cherry

# ----- Omni 实时模式 -----
OMNI_MODE=false
OMNI_MODEL=qwen3.5-omni-flash-realtime
OMNI_VOICE=Cherry

# ----- 额度管控 -----
DAILY_TTS_QUOTA=10.0

# ----- 会话配置 -----
SESSION_TIMEOUT=600
SSE_HEARTBEAT_INTERVAL=3
MAX_CONTEXT_ROUNDS=10

# ----- 开发模式 -----
DEBUG=true
